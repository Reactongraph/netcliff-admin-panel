########################################
# API & App Config
########################################
# Backend base URL used by the admin panel
REACT_APP_BASE_URL=

# Shared secret key (must match backend `secretKey`)
REACT_APP_SECRET_KEY=

# Project name shown in UI (optional)
REACT_APP_PROJECT_NAME=

########################################
# Azure Storage & CDN (for images/assets)
########################################
# Public Azure Blob Storage container used by the admin
REACT_APP_AZURE_STORAGE_CONTAINER_NAME=

# Public CDN endpoint that fronts the storage account
REACT_APP_AZURE_CDN_ENDPOINT=

########################################
# Deprecated / Legacy keys from existing .env
# (Not referenced in current admin-panel code)
########################################
# REACT_APP_BUCKET_NAME=alright
# REACT_APP_AWS_HOSTNAME=https://s3.us-east-1.amazonaws.com
# REACT_APP_AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
# REACT_APP_AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
# REACT_APP_AZURE_STORAGE_ACCOUNT_URL=https://your-account-name.blob.core.windows.net

